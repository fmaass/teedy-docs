    <!-- Filesystem-safe, millisecond-resolution build timestamp. Combined with the per-invocation
         nonce (teedy.run.nonce, generated by the antrun execution below) into the per-run token that
         isolates each test run's on-disk state (docs.home storage + java.io.tmpdir); see the
         maven-surefire-plugin config below. The timestamp alone is NOT unique — two invocations
         starting in the same millisecond would collide — so it serves only human-readable ordering of
         the run dirs; the nonce carries the uniqueness guarantee. The default format contains ':',
         unsuitable for a directory name. -->
    <maven.build.timestamp.format>yyyyMMdd-HHmmss-SSS</maven.build.timestamp.format>

    <!-- Default (empty) surefire argLine. The isolated java.io.tmpdir is appended in the surefire
         config below via @{argLine} late-substitution; this default guarantees @{argLine} resolves even
         before the JaCoCo prepare-agent goal populates the property. -->
    <argLine></argLine>

