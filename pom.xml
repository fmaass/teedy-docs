  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <version>${org.apache.maven.plugins.maven-antrun-plugin.version}</version>
        <executions>
          <!-- Generate the per-invocation isolation nonce and create the isolated per-run
               java.io.tmpdir BEFORE the surefire JVM forks.

               NONCE: <tempfile createfile="true"> atomically creates a uniquely-named marker file
               (File.createTempFile semantics: the name is random and creation fails-and-retries on
               collision), so teedy.run.nonce is genuinely unique PER MAVEN INVOCATION — even for two
               invocations racing in the same worktree in the same millisecond, which the build
               timestamp alone cannot distinguish. exportAntProperties publishes it as a project
               property; the surefire config below (same module, later phase) interpolates it. Each
               MODULE generates its own nonce: a module's forks only need isolation from other
               INVOCATIONS — sibling modules are already separated by their distinct target dirs — so
               no cross-module property passing is needed.

               TMPDIR: the forked JVM is launched with -Djava.io.tmpdir pointing at the leaf dir (see
               the surefire config below); it must already exist, because a test's first
               Files.createTempFile would otherwise fail (surefire itself only WARNS on a missing
               tmpdir). This runs in the reactor JVM, where ${surefire.forkNumber} is NOT defined, so
               the fork's leaf dir is created explicitly: with forkCount=1 (below) the sole fork is
               always numbered 1. If forkCount is ever raised, add the matching f2..fN dirs here (or
               move creation into an in-fork hook). docs.home needs no pre-creation —
               DirectoryUtil.getBaseDataDirectory() creates it lazily on first use. -->
          <execution>
            <id>create-isolated-test-tmpdir</id>
            <phase>process-test-resources</phase>
            <goals>
              <goal>run</goal>
            </goals>
            <configuration>
              <exportAntProperties>true</exportAntProperties>
              <target>
                <mkdir dir="${project.build.directory}/teedy-it"/>
                <tempfile property="teedy.run.nonce.path" destdir="${project.build.directory}/teedy-it"
                          prefix="run-" suffix=".marker" createfile="true"/>
                <basename property="teedy.run.nonce" file="${teedy.run.nonce.path}" suffix=".marker"/>
                <mkdir dir="${project.build.directory}/teedy-it/${maven.build.timestamp}-${teedy.run.nonce}/tmp/f1"/>
              </target>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-war-plugin</artifactId>
        <version>${org.apache.maven.plugins.maven-war-plugin.version}</version>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>${org.apache.maven.plugins.maven-jar-plugin.version}</version>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${org.apache.maven.plugins.maven-surefire-plugin.version}</version>
        <configuration>
          <forkCount>1</forkCount>
          <reuseForks>false</reuseForks>
          <!-- Isolate every test run's on-disk state so one run never observes another run's (or a
               parallel worktree's) leftover storage files or sismics_docs* temps — the shared
               $TMPDIR/storage and $TMPDIR temps were the root of the order-/run-dependent flakes
               (#94). These are supplied at JVM LAUNCH (inherited by every reactor module, including
               docs-core) rather than in a test setUp, because EnvironmentUtil caches docs.home into a
               static field at class-init, before any @BeforeEach runs.

               Uniqueness = the per-invocation nonce ${teedy.run.nonce} (generated per module by the
               antrun execution above; atomic tempfile creation guarantees no two invocations ever get
               the same value, even in the same millisecond) + the ordering timestamp + the module's own
               ${project.build.directory} + the surefire fork number. The build-dir separates parallel
               worktrees (distinct absolute target dirs); ${surefire.forkNumber} disambiguates
               concurrent forks should forkCount ever exceed 1. Neither the timestamp nor forkNumber
               alone would suffice — the timestamp is not unique across same-millisecond invocations,
               and fork numbers are reused sequentially across a run.

               docs.home holds storage/db/lucene (DirectoryUtil creates it lazily). It is supplied via
               systemPropertyVariables (surefire sets it as a system property inside the fork before
               tests run; EnvironmentUtil reads it at its class-init, which happens later, during the
               test) — verified: storage lands under the isolated home dir.

               java.io.tmpdir, in contrast, MUST be supplied at JVM LAUNCH via argLine, NOT via
               systemPropertyVariables. Files.createTempFile / File.createTempFile resolve the temp
               directory from jdk.internal.util.StaticProperty.javaIoTmpDir(), which is cached ONCE at VM
               startup; a later System.setProperty (which is what systemPropertyVariables does) does not
               change it, so the temps would silently keep landing in the shared system tmpdir. Passing
               -Djava.io.tmpdir on the launch command line sets the cached value correctly. @{argLine}
               preserves the JaCoCo agent that prepare-agent injects into the argLine property. The leaf
               dir is pre-created by the antrun execution above because the JVM needs it at bootstrap. -->
          <argLine>@{argLine} -Djava.io.tmpdir=${project.build.directory}/teedy-it/${maven.build.timestamp}-${teedy.run.nonce}/tmp/f${surefire.forkNumber}</argLine>
          <systemPropertyVariables>
            <docs.home>${project.build.directory}/teedy-it/${maven.build.timestamp}-${teedy.run.nonce}/home/f${surefire.forkNumber}</docs.home>
          </systemPropertyVariables>
        </configuration>
      </plugin>

      <!-- Instrument every reactor module. The aggregate report is deliberately
           emitted by docs-web, the last module, after upstream module tests ran. -->
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>${org.jacoco.jacoco-maven-plugin.version}</version>
        <executions>
          <execution>
            <id>prepare-agent</id>
            <goals>
              <goal>prepare-agent</goal>
            </goals>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.eclipse.jetty.ee10</groupId>
        <artifactId>jetty-ee10-maven-plugin</artifactId>
        <version>${org.eclipse.jetty.version}</version>
      </plugin>
    </plugins>
  </build>

